# Square POS Integration Configuration
# Fill in your actual credentials from https://developer.squareup.com/apps

# ============================================
# SQUARE CREDENTIALS (Required - Get from Square Dashboard)
# ============================================

# Your Square Access Token
# Get from: Developers → Credentials → Production Access Token
SQUARE_ACCESS_TOKEN=put_your_square_access_token_here

# Your Square Location ID
# Get from: Developers → Credentials → Location ID
SQUARE_LOCATION_ID=put_your_location_id_here

# Your Square Application ID
# Get from: Developers → Credentials → Application ID
SQUARE_APPLICATION_ID=put_your_app_id_here

# Environment: 'production' or 'sandbox'
SQUARE_ENVIRONMENT=production

# ============================================
# SERVER CONFIGURATION
# ============================================

# Backend server port
PORT=5000

# Node environment
NODE_ENV=development

# ============================================
# KEEP EXISTING CONFIGURATIONS
# ============================================
# Do not remove or modify these - they're for your existing integrations

# Stripe (existing - keep as is)
STRIPE_SECRET_KEY=sk_live_your_existing_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_existing_webhook_secret

# Firebase (existing - keep as is)
FIREBASE_PROJECT_ID=your_firebase_project
FIREBASE_PRIVATE_KEY=your_firebase_key
FIREBASE_CLIENT_EMAIL=your_firebase_email

# Shopify (existing - keep as is)
SHOPIFY_STORE_NAME=your_shopify_store
SHOPIFY_ACCESS_TOKEN=your_shopify_token

# Client domain (existing - keep as is)
CLIENT_DOMAIN=http://localhost:3000
